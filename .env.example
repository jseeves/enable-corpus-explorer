# Restoration Intelligence — environment variables
# Copy to .env (and to app/.env.local) and fill in.

# Anthropic — for generation in /api/ask and for the optional metadata enrichment in ingestion.
ANTHROPIC_API_KEY=

# Voyage AI — for embeddings (voyage-3) and reranking (rerank-2). Free tier: 200M tokens.
# Sign up at https://voyageai.com
VOYAGE_API_KEY=

# Pinecone — for the hybrid index. Free tier handles ~5K chunks easily.
# Sign up at https://pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX_NAME=restoration-intelligence

# Optional: Pinecone environment / cloud region. Leave default unless you have a specific region requirement.
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Optional: which Claude model for generation in /api/ask. Defaults to Sonnet.
CLAUDE_MODEL=claude-sonnet-4-5

# Optional: which Claude model for metadata enrichment (ingestion/enrich.py). Sonnet is overkill; Haiku is fine.
CLAUDE_ENRICH_MODEL=claude-haiku-4-5-20251001
